<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ name }} | Portfolio</title>
    <style>
        :root {
            --bg-color: #0d1117;
            --text-main: #c9d1d9;
            --accent: #58a6ff;
            --card-bg: #161b22;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.6;
            margin: 0;
            padding: 0;
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        header {
            text-align: center;
            margin-bottom: 50px;
        }
        header h1 {
            color: #ffffff;
            font-size: 2.5rem;
            margin-bottom: 10px;
        }
        .tagline {
            font-size: 1.2rem;
            color: var(--accent);
        }
        .skills-list {
            list-style: none;
            padding: 0;
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
        }
        .skills-list li {
            background: var(--card-bg);
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.9rem;
            border: 1px solid #30363d;
        }
        .section-title {
            border-bottom: 1px solid #30363d;
            padding-bottom: 10px;
            margin-top: 40px;
            color: #ffffff;
        }
        .project-card {
            background: var(--card-bg);
            border: 1px solid #30363d;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .project-title {
            margin-top: 0;
            color: var(--accent);
        }
        .tech-stack {
            font-size: 0.85rem;
            color: #8b949e;
            margin-top: 15px;
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>{{ name }}</h1>
        <p class="tagline">{{ tagline }}</p>
        
        <ul class="skills-list">
            {% for skill in skills %}
                <li>{{ skill }}</li>
            {% endfor %}
        </ul>
    </header>

    <h2 class="section-title">Featured Projects</h2>

    {% if projects %}
        {% for project in projects %}
            <div class="project-card">
                <h3 class="project-title">{{ project.title }}</h3>
                {% if project.role %}
                    <p><strong>Role:</strong> {{ project.role }}</p>
                {% endif %}
                <p>{{ project.description }}</p>
                <div class="tech-stack">
                    <strong>Tech Stack:</strong> {{ project.tech_stack }}
                </div>
                {% if project.github_link %}
                    <a href="{{ project.github_link }}" target="_blank" style="color: var(--accent); text-decoration: none; display: inline-block; margin-top: 10px;">View Project &rarr;</a>
                {% endif %}
            </div>
        {% endfor %}
    {% else %}
        <!-- Placeholder content before you add database entries -->
        <div class="project-card">
            <h3 class="project-title">EvoFuzz</h3>
            <p>Automated web vulnerability discovery utilizing genetic algorithms to efficiently map and exploit attack vectors.</p>
            <div class="tech-stack"><strong>Tech Stack:</strong> Python, Genetic Algorithms</div>
        </div>

        <div class="project-card">
            <h3 class="project-title">SmileCheck</h3>
            <p><strong>Role:</strong> Team Lead</p>
            <p>Dental clinic management application featuring automated scheduling, an AI chatbot, and a cryptographic ledger for secure records.</p>
            <div class="tech-stack"><strong>Tech Stack:</strong> Python, Django, MySQL</div>
        </div>

        <div class="project-card">
            <h3 class="project-title">OptiBraille</h3>
            <p>Mobile application that utilizes machine learning and OBR algorithms to interpret tactile character patterns into text and speech.</p>
            <div class="tech-stack"><strong>Tech Stack:</strong> Python, OpenCV, Machine Learning</div>
        </div>
    {% endif %}

</div>

</body>
</html>